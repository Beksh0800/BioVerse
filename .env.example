# Ключ OpenRouter для AI-помощника: https://openrouter.ai/keys
# Пока пусто — чат работает в демо-режиме с заготовленным ответом,
# сайт при этом не падает.
OPENROUTER_API_KEY=

# Необязательно. По умолчанию google/gemini-2.5-flash-lite —
# самый быстрый и дешёвый из проверенных на казахском языке.
# Если понадобятся более подробные ответы (но вдвое медленнее и дороже):
# OPENROUTER_MODEL=google/gemini-2.5-flash
# Точные идентификаторы: https://openrouter.ai/models
# Неверный id не вызовет ошибку в интерфейсе — чат уйдёт в демо-режим,
# а причина будет видна в консоли сервера.
OPENROUTER_MODEL=

# Постоянный адрес сайта — куда ведут QR-коды на сертификате и в портфолио.
# Если не задать, код возьмёт адрес страницы, откуда его открыли: с локальной
# машины в PDF попадёт localhost (такая ссылка не откроется ни у кого), а с
# превью-деплоя Vercel — временный адрес, который меняется при каждом пуше.
# Заполнять боевым доменом БЕЗ слэша в конце, например:
# NEXT_PUBLIC_SITE_URL=https://bioverse.vercel.app
NEXT_PUBLIC_SITE_URL=
